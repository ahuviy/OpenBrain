# Open Brain Environment Variables
# Copy to .env and fill in your values

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=openbrain
DB_USER=openbrain
DB_PASSWORD=changeme

# Embedder Provider: "ollama" (local, free) or "openrouter" (cloud, paid)
EMBEDDER_PROVIDER=ollama
EMBEDDING_DIMENSIONS=768

# Ollama (when EMBEDDER_PROVIDER=ollama)
OLLAMA_ENDPOINT=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_LLM_MODEL=llama3.2

# OpenRouter (when EMBEDDER_PROVIDER=openrouter)
# OPENROUTER_API_KEY=sk-or-your-key-here
# OPENROUTER_EMBED_MODEL=openai/text-embedding-3-small
# OPENROUTER_LLM_MODEL=openai/gpt-4o-mini

# Azure OpenAI (when EMBEDDER_PROVIDER=azure-openai)
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_KEY=your-azure-openai-key
# AZURE_OPENAI_EMBED_DEPLOYMENT=text-embedding-3-small
# AZURE_OPENAI_LLM_DEPLOYMENT=gpt-4o-mini
# AZURE_OPENAI_API_VERSION=2024-06-01

# MCP Server Authentication
# Generate with: openssl rand -hex 32
MCP_ACCESS_KEY=your-64-char-hex-key-here

# Public HTTPS origin of this deployment (no trailing slash), e.g. https://openbrain.fly.dev
# Required to enable the OAuth connector for claude.ai web + mobile. When set (with
# MCP_ACCESS_KEY), the server exposes the Streamable HTTP endpoint at PUBLIC_BASE_URL/mcp
# behind OAuth. When unset, OAuth + /mcp are disabled and only the legacy /sse (key) works.
# Apply the OAuth tables once with: npm run db:migrate  (knex migration 004_oauth)
# PUBLIC_BASE_URL=https://openbrain.fly.dev

# Failure push notifications (optional) — set to an ntfy topic URL to get a
# loud phone alert when a tool call fails or deep health detects DB/OpenRouter down.
# NTFY_URL=https://ntfy.sh/your-secret-topic

# Server Ports
API_PORT=8000
MCP_PORT=8080

# Logging
LOG_LEVEL=info
